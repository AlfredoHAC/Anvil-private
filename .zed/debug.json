// Project-local debug tasks
//
// For more documentation on how to configure debug tasks,
// see: https://zed.dev/docs/debugger
[
  {
    "label": "LLDB (Windows)",
    "build": {
      "command": "cmd",
      "args": [
        "/c",
        "scripts\\build.bat",
        "debug"
      ],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "${ZED_WORKTREE_ROOT}/bin/Debug/Anvil.exe",
    "request": "launch",
    "adapter": "CodeLLDB",
  },
  {
    "label": "GDB (Linux)",
    "build": {
      "command": "bash",
      "args": [
        "scripts/build.sh",
        "debug"
      ],
      "cwd": "$ZED_WORKTREE_ROOT"
    },
    "program": "${ZED_WORKTREE_ROOT}/bin/Debug/Anvil",
    "request": "launch",
    "adapter": "GDB",
  }
]
